{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RangeTranslator",
  "version": "0.1.0",
  "identifier": "com.rangetranslator.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "RangeTranslator",
        "width": 400,
        "height": 280,
        "minWidth": 380,
        "minHeight": 260,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": false,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all"
  }
}