{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "RangeTranslator",
  "version": "0.1.0",
  "identifier": "com.rangetranslator.app",
  "build": {
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "label": "panel",
        "title": "RangeTranslator",
        "width": 400,
        "height": 420,
        "minWidth": 380,
        "minHeight": 400,
        "decorations": false,
        "transparent": false,
        "resizable": true,
        "alwaysOnTop": false,
        "center": true
      },
      {
        "label": "settings",
        "title": "Settings",
        "width": 450,
        "height": 450,
        "minWidth": 400,
        "minHeight": 400,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": false,
        "center": true,
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false,
    "targets": "all",
    "resources": {
      "../range-translator-runtime": "range-translator-runtime",
      "../benchmarks": "benchmarks"
    }
  }
}