# ==========================================
# Agent Core Settings
# ==========================================
# 設定 TRANSLATOR 代理人要使用的 AI 供應商
# 可選值: ollama, geminiflow, vertex
AGENT_TRANSLATOR_PROVIDER=ollama

# 設定 TRANSLATOR 代理人要使用的模型名稱
# 例如: qwen3:8b, gemini-1.5-pro-preview-0409, gemini-3-pro
AGENT_TRANSLATOR_MODEL=qwen3:8b

# ==========================================
# Ollama Provider Settings
# ==========================================
# Ollama 伺服器的 API 網址
PROVIDER_OLLAMA_URL=http://localhost:11434
# Ollama 模型對話逾時時間 (秒)
RANGE_TRANSLATOR_OLLAMA_CHAT_TIMEOUT_SECONDS=60000
# Ollama 模型的記憶體保留時間
RANGE_TRANSLATOR_OLLAMA_KEEP_ALIVE=30m

# ==========================================
# GeminiFlow Provider Settings
# ==========================================
# GeminiFlow 伺服器的 API 網址
PROVIDER_GEMINIFLOW_URL=http://127.0.0.1:8000

# ==========================================
# Vertex AI Provider Settings
# ==========================================
# Google Cloud Project ID
PROVIDER_VERTEX_PROJECT_ID=your-project-id
# Google Cloud 區域
PROVIDER_VERTEX_REGION=us-central1

# ==========================================
# System Settings
# ==========================================
# 存放 AI 對話紀錄與 Log 的目錄路徑
RANGE_TRANSLATOR_AI_LOG_DIR=./.runtime/ai-log
